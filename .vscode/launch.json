{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Windows MSVC Debug (fs_tests)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/out/build/windows-msvc-debug/Debug/fs_tests.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "visualizerFile": "${workspaceFolder}/../eigen-pretty-printers/natvis/Eigen.natvis",
            "preLaunchTask": "CMake: Build windows-msvc-debug"
        },
        {
            "name": "Windows GCC Debug (fs_tests)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/out/build/windows-gcc-debug/fs_tests.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "EIGEN_PRINTERS_ROOT",
                    "value": "${workspaceFolder}/../eigen-pretty-printers"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
            "preLaunchTask": "CMake: Build windows-gcc-debug",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                },
                {
                    "description": "Load Eigen pretty-printers (shared root)",
                    "text": "python import importlib.util; p=r'${workspaceFolder}/../eigen-pretty-printers/gdb/printers.py'; s=importlib.util.spec_from_file_location('eigen_printers', p); m=importlib.util.module_from_spec(s); s.loader.exec_module(m); m.register_eigen_printers(gdb)",
                    "ignoreFailures": false
                }
            ]
        },
        {
            "name": "Windows Clang Debug (gdb, fs_tests)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/out/build/windows-clang-debug/fs_tests.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "EIGEN_PRINTERS_ROOT",
                    "value": "${workspaceFolder}/../eigen-pretty-printers"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
            "preLaunchTask": "CMake: Build windows-clang-debug",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                },
                {
                    "description": "Load Eigen pretty-printers (shared root)",
                    "text": "python import importlib.util; p=r'${workspaceFolder}/../eigen-pretty-printers/gdb/printers.py'; s=importlib.util.spec_from_file_location('eigen_printers', p); m=importlib.util.module_from_spec(s); s.loader.exec_module(m); m.register_eigen_printers(gdb)",
                    "ignoreFailures": false
                }
            ]
        },
        {
            "name": "Windows Clang Debug (lldb, fs_tests)",
            "type": "lldb-dap",
            "request": "launch",
            "program": "${workspaceFolder}/out/build/windows-clang-debug/fs_tests.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "EIGEN_PRINTERS_ROOT",
                    "value": "${workspaceFolder}/../eigen-pretty-printers"
                }
            ],
            "externalConsole": false,
            "debugAdapterPath": "C:/msys64/ucrt64/bin/lldb-dap.exe",
            "initCommands": [
                "command script import ${workspaceFolder}/../eigen-pretty-printers/lldb/eigen_printers.py"
            ],
            "preLaunchTask": "CMake: Build windows-clang-debug"
        },
        {
            "name": "Linux GCC Debug (fs_tests)",
